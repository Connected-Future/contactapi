# Postgres connection string used by Drizzle (client + migrations).
# Use a Neon connection string in production, or a local Postgres for dev.
# Neon:  postgres://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
# Local: postgres://postgres:postgres@localhost:5432/contactapi
DATABASE_URL=

# Better Auth — dashboard accounts & sessions.
# Secret for signing session cookies. Generate one with: openssl rand -hex 32
BETTER_AUTH_SECRET=
# Public base URL of the app (used for cookies / CSRF origin checks).
# Local dev: http://localhost:3000 — set to the deployed URL in production.
BETTER_AUTH_URL=http://localhost:3000

# Encrypts API keys at rest so the dashboard can reveal them later. Generate
# with: openssl rand -hex 32. Optional locally (falls back to BETTER_AUTH_SECRET)
# but set a dedicated value in production. Rotating it makes existing keys
# unrevealable (auth still works — that uses the hash) until they're recreated.
API_KEY_ENC_SECRET=
